---
- name: Deploy and run application on multiple machines
  hosts: all
  become: yes

  vars:
    repo_url: "https://github.com/votre-utilisateur/votre-repo.git"
    repo_dest: "/path/to/clone/repo"

  tasks:

    - name: pull the project
      shell: |
        cd bench-secretsharing && git pull && cd ..
      tags: pull
      
    - name: build the project
      shell: |
        cd bench-secretsharing/nodes && cargo build --release
      tags: compile
        
