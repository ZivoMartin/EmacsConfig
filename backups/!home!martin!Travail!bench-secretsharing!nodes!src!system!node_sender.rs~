use tokio::sync::mpsc::Sender;
use crate::Sign;

pub enum NodeMessage {
    AvssSimplDealerMessage(u16, u32, Sign)
}


impl NodeMessage {

    fn to_usize(&self) -> usize {
        match self {
            NodeMessage::AvssSimplDealerMessage(_, _, _) => 0
        }
    }

}

pub struct NodeSender {
    senders: Vec<Sender<NodeMessage>>
}

impl NodeSender {

    pub fn new(c: usize) -> Self {
        NodeSender {
            senders: Vec::with_capacity(c)
        }
    }


    pub async fn send(&self, msg: NodeMessage) {
        let index = msg.to_usize();
        self.senders[index].send(msg).await.expect("Failed to send a message");
    }

}
