use serde::{Serialize, Deserialize};

#[derive(Clone, Default, Serialize, Deserialize)]
pub struct Configuration {
    t: u16,
    l: u16,
    n: u16,
    index: u16,
    is_byz: bool,
    dealer: u16,
    op_id: u32,    
//    dom: EvaluationDomain,
//    batch_dom: BatchEvaluationDomain,
}


impl Configuration {

    pub fn new(
        t: u16,
        l: u16,
        n: u16,
        index: u16,
        is_byz: bool,
        dealer: u16,
        op_id: u32
    ) -> Self {
        Configuration {
            t, l, n, index, is_byz, dealer, op_id
        }
    }

    pub fn change_index(&mut self, index: u16) {
        self.index = index;
    }

    pub fn change_byz_comp(&mut self, is_byz: bool) {
        self.is_byz = is_byz;
    }
    
    pub fn t(&self) -> u16 {
        self.t
    }

    pub fn l(&self) -> u16 {
        self.l
    }
    
    pub fn n(&self) -> u16 {
        self.n
    }
    
    pub fn index(&self) -> u16 {
        self.index
    }
    
    pub fn is_byz(&self) -> bool {
        self.is_byz
    }

    pub fn dealer(&self) -> u16 {
        self.dealer
    }
    
    pub fn op_id(&self) -> u32 {
        self.op_id
    }

    pub fn degree(&self) -> u32 {
        2 * self.t as u32
    }

    pub fn is_dual_threshold(&self) -> bool {
        self.l == self.t
    }
    
}

