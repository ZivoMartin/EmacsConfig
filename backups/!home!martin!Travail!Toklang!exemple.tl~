#DEFINE

SYMB: digit letter symbol
TPRIM: Keyword Type Operator Number Ident Symbol
GROUPS: Expression Value

#CHAR_RULES
digit = @DIGIT
letter = @LETTER
symbol = @OTHER

#TPRIM_RULES
Number = digit || (digit && Number)
Ident = letter || (digit && Ident || Ident || digit)
Keyword = letter || (letter && Keyword)  
Keyword in ["RESET", "CREATE", "TABLE", "INTO", "DROP", "VALUES", "SELECT", "PRIMARY", "KEY", "FROM", "WHERE", "UPDATE", "SET"]
Symbol = symbol || digit || letter
Operator = symbol || (symbol && symbol)
Operator in ["+", "-", "*", "/", "%", "<", ">", "<=", ">=", "==", "!=", "||", "&&"]
Type = letter || (letter && Keyword)  
Type in ["BOOL", "INT", "STRING"]

#GROUPS_RULES
  
Expression = (Value{END} && Operator && Expression) || (Symbol{"("} && Expression && Symbol(")", END) && Operator && Expression)     
Value = String || Ident || Number || (Symbol{"-"} && Value)               

        
        
        