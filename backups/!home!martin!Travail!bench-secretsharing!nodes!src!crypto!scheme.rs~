pub fn compute_comm_and_shares(
    n: u16,
    degree_bound: u32,
    _secret: u128,
) -> (Commitment, Vec<Share>) {
    let n = n as usize;
    let rng = &mut thread_rng();
    let s = random_scalar(rng);

    let seed = b"hello";
    let g = G1Projective::generator(); 
    let h = G1Projective::hash_to_curve(seed, DST_PVSS_PUBLIC_PARAMS_GENERATION.as_slice(), b"h");
    let bases = [g, h];
    
    let batch_dom = BatchEvaluationDomain::new(n);
    let dom = batch_dom.get_subdomain(n);       

    let p = Polynomial::rand(rng, degree_bound as usize);

    let (f_evals, r_evals) = p.get_evals(&dom, n);

    let mut shares: Vec<Share> = Vec::with_capacity(n);
    for i in 0..n {
        shares.push(Share::new(i as u16, [f_evals[i], r_evals[i]]));
    }

    let mut coms:Vec<G1Projective> = Vec::with_capacity(n);
    for i in 0..n {
        let scalars = [f_evals[i], r_evals[i]];
        coms.push(G1Projective::multi_exp(&bases, scalars.as_slice())); 
    }
    (Commitment::new(bases, coms) , shares)

}

