SDL_Color create_color(int r, int g, int b, int a) {
  return (SDL_Color) {r, g, b, a};
}


SDL_Rect init_rect(int x, int y, int w){
  return (SDL_Rect){.h = w-1, .w = w-1, .x = x, .y = y};
} 

int compute_ts(Env* env) {
  return (w_height(env)*(1-(GRIDDECALTOP+GRIDDECALBOT)))/ game_nb_rows(get_game(env));
}

#define CENTER 0.5
void compute_decal_grid(Env* env, int tileSize, int* x, int* y) {
  *x = (w_width(env)*CENTER) - ((tileSize*game_nb_cols(get_game(env)))/2);
  *y = GRIDDECALTOP*w_height(env);
}

void resize_rect(SDL_Rect* r, int tileSize) {
  r->w *= RESIZE_CONST_RECT;
  r->h = r->w;
  r->x += tileSize/2-(r->w/2);
  r->y += tileSize/2-(r->w/2);
}




void draw_single_square(Env* env, int w, int h, int decalWidth, int decalHeight, int tileSize) {
  SDL_Rect r = init_rect(w*tileSize+decalWidth, h*tileSize+decalHeight, tileSize);
  SDL_RenderCopy(get_ren(env), get_frame_texture(env, game_get_color(get_game(env),h, w)), NULL, &r);
  resize_rect(&r, tileSize);
  constraint c = game_get_constraint(get_game(env), h, w);
  if (c != -1) {
    status s = game_get_status(get_game(env), h, w);
    if (s == SATISFIED) {
      SDL_RenderCopy(get_ren(env), env->numbers[SATISFIED_INDEX][c], NULL, &r);
    }else if (s == ERROR) {
      SDL_RenderCopy(get_ren(env), env->numbers[ERROR_INDEX][c], NULL, &r);
    }else if (game_get_color(get_game(env), h, w) == WHITE){
      SDL_RenderCopy(get_ren(env), env->numbers[WHITE_TEXT_INDEX][c], NULL, &r);
    }else{
      SDL_RenderCopy(get_ren(env), env->numbers[BLACK_TEXT_INDEX][c], NULL, &r);
    }
  }
}

void draw_game(Button* b){
  Env* env = button_env(b);
  game g = get_game(env);
  uint width = game_nb_cols(g);
  uint height = game_nb_rows(g);
  int tileSize = compute_ts(env);
  b->w = tileSize*width;
  b->h = w_height(env)*button_rheight(b);
  SDL_SetWindowMinimumSize(win(env),tileSize*width, tileSize*height);
  int decalWidth, decalHeight;
  compute_decal_grid(env, tileSize, &decalWidth, &decalHeight);
  for(int i = 0; i < width; i++){
    for(int j = 0; j < height; j++){
      draw_single_square(env, i, j, decalWidth, decalHeight, tileSize);
    }
  } 

}

void display_current_scene(Env* env){
  SDL_RenderCopy(get_ren(env), scene_get_background(get_current_scene(env)), NULL, NULL);
}


void display_scenes(Env* env) {
  display_current_scene(env);
  for(int i = 0; i<nb_button(env); i++) {
      display_button(get_button(env, i));  
  }
}


void render(Env *env) { /* PUT YOUR CODE HERE TO RENDER TEXTURES, ... */
  SDL_GetWindowSize(win(env), &env->w, &env->h);
  display_scenes(env);
}



void process(Env *env, SDL_Event *e) {
  int w, h;
  SDL_GetWindowSize(win(env) , &w, &h);
  game g = get_game(env);
  if (e->type == SDL_QUIT) {
    stop_the_search(env);
    env->running = false;
  } else if (e->type == SDL_MOUSEBUTTONUP) 
    click_release(env);
  else if (e->type == SDL_MOUSEMOTION){
    SDL_Point mouse;
    SDL_GetMouseState(&mouse.x, &mouse.y);
    mouse_move(env, mouse);
  }else if (e->type == SDL_TEXTINPUT) 
    kpress(env, e->text.text[0]);
  else if (e->type == SDL_MOUSEBUTTONDOWN) {
    SDL_Point mouse;
    SDL_GetMouseState(&mouse.x, &mouse.y);
    set_last_coordinate(env, mouse);
    new_clic(env);
  } else if (e->type == SDL_KEYDOWN) {
    switch (e->key.keysym.sym) {
      case SDLK_ESCAPE: 
      if (get_scene_index(env) == Game){
         change_scene(env, Settings);
         break;
      }else{
        change_scene(env, Game);
        break;
      }
      case SDLK_RETURN:
        activate_input(env);
        break;
      case SDLK_BACKSPACE:
        input_delete_char(button_get_input(get_active_input(env)));
        break;
      case SDLK_a: 
        if(!get_active_input(env)) game_undo(g);
        break;
      case SDLK_e:  
        if(!get_active_input(env)) game_redo(g);
        break;
      case SDLK_r: 
        if(!get_active_input(env)) game_restart(g);
        break;
      case SDLK_s: 
        if(!get_active_input(env)) game_solve(g);
        break;

    }
  }

}

void clean(Env *env) {
  destroy_env(env);
  IMG_Quit();
  TTF_Quit();
  SDL_Quit();
}
    