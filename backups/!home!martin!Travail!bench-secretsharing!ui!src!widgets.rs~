
fn input(fixed: &Fixed, placeholder: &str, x: i32, y: i32) -> EntryBuffer {
    let buf = EntryBuffer::new(None);
    let entry = Entry::builder()
        .placeholder_text(placeholder)
        .buffer(&buf)
        .build();
    fixed.put(&entry, x, y);
    entry.set_size_request(300, 30);
    buf
}

fn button(fixed: &Fixed, text: &str, x: i32, y: i32, w: i32, h: i32) -> Button {
    let button = Button::with_label(text);
    fixed.put(&button, x, y);
    button.set_size_request(w, h);
    button
}

