pub enum CommandCode {
    INIT,
    REMOVE,
    LEAVE,
    DEALTHIS,
    SHARE,
    ACK,
    REST,
    SETUP,
    KEY
}

impl From<u8> for CommandCode {
     fn from(code: u8) -> Self {
         match code {
             0 => CommandCode::INIT,
             1 => CommandCode::REMOVE,
             2 => CommandCode::LEAVE,
             3 => CommandCode::DEALTHIS,
             4 => CommandCode::SHARE,
             5 => CommandCode::ACK,
             6 => CommandCode::REST,
             7 => CommandCode::SETUP,
             8 => CommandCode::KEY,
             _ => panic!("Invalid code")
         }
     }
}

impl Into<u8> for CommandCode {
    fn into(self) -> u8 {
        match self {
            CommandCode::INIT => 0,
            CommandCode::REMOVE => 1,
            CommandCode::LEAVE => 2,
            CommandCode::DEALTHIS => 3,
            CommandCode::SHARE => 4,
            CommandCode::ACK => 5,
            CommandCode::REST => 6,
            CommandCode::SETUP => 7,
            CommandCode::KEY => 8
        }
    }
}
