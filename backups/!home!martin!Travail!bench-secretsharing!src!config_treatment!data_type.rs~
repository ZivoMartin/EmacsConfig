pub use std::mem::ManuallyDrop;

#[derive(Eq, Hash, PartialEq, Clone)]
pub enum DataType {
    Average,
    Median,
    Details,
}

pub union ProcessResult {
    val: u128,
    details: ManuallyDrop<String>,
}

impl ProcessResult {
    pub fn details(details: ManuallyDrop<String>) -> ProcessResult {
        ProcessResult { details }
    }

    pub fn val(val: u128) -> ProcessResult {
        ProcessResult { val }
    }

    pub fn get_details(&self) -> &String {
        unsafe { &self.details }
    }

    pub fn get_val(&self) -> u128 {
        unsafe { self.val }
    }
}

impl DataType {
    pub fn from_str(s: &str) -> Result<DataType, &'static str> {
        Ok(match s {
            "average" => DataType::Average,
            "median" => DataType::Median,
            "details" => DataType::Details,
            _ => return Err("invalid data result"),
        })
    }

    pub fn as_str(&self) -> &'static str {
        match self {
            DataType::Average => "average",
            DataType::Median => "median",
            DataType::Details => "details",
        }
    }

    pub fn process(&self, field: &str, datas: &Vec<u128>) -> ProcessResult {
        match self {
            Self::Average => ProcessResult::val(datas.iter().sum::<u128>() / datas.len() as u128),
            Self::Median => ProcessResult::val(datas[datas.len() / 2]),
            Self::Details => {
                ProcessResult::details(ManuallyDrop::new(format!("{field}: {datas:?}")))
            },
        }
    }
}
