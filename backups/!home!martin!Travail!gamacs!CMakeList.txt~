add_library(game src/lib/game.c src/lib/game_aux.c src/lib/game_ext.c src/dataStructures/queue.c src/dataStructures/dblists.c src/lib/commun_functions.c src/lib/game_tools.c)
add_library(utilitary src/lib/commun_functions.c src/dataStructures/queue.c src/dataStructures/dblists.c) # YOU NEED TO LINK THIS LIBRARY TO YOUR EXECUTABLES

#Graphical interface
include_directories(${SDL2_ALL_INC})
add_executable(game_sdl interface/lib/model.c interface/main.c interface/lib/button.c interface/lib/env.c interface/lib/scene.c interface/lib/input.c interface/lib/cursor.c)
target_link_libraries(game_sdl ${SDL2_ALL_LIBS} game utilitary)

file(COPY res DESTINATION ${CMAKE_CURRENT_BINARY_DIR})
file(COPY game_textfiles DESTINATION ${CMAKE_CURRENT_BINARY_DIR})

# ----------------------------------TO READ VERY IMPORTANT-----------------------------------------------------

# Dont forget to link the utilitary library to your executables or else when you compile with your own game
