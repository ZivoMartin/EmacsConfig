use std::ops::AddAssign;
pub use std::time::Instant;
pub const NO_DEBIT: u64 = 0;
pub type Duration = u128; // in ms
type ResultField = String;
pub const RESULT_FIELDS_SIZE: usize = 112;

static POSSIBLE_RESULT_FIELD: [&str; 7] = [
    "verify",
    "dealing",
    "first_receiv",
    "broadcasting",
    "messages_computing",
    "total",
    "reconstruct",
];

as_number!(
    usize,
    enum TypeResultField {
        Verify,
        Dealing,
        FirstReceiv,
        BroadCasting,
        MessagesComputing,
        Total,
        Reconstruction,
    }
);
const NB_FIELD: usize = 7;

#[derive(Clone, Debug, Default)]
pub struct ResultFields {
    results: Vec<Duration>,
}

impl AddAssign for ResultFields {
    fn add_assign(&mut self, other: ResultFields) {
        self.results
            .iter_mut()
            .zip(other.results.iter())
            .for_each(|(my, his)| {
                *my = *my + *his;
            })
    }
}

impl ResultFields {
    pub fn new() -> Self {
        ResultFields {
            results: vec![0; NB_FIELD],
        }
    }

    pub fn get(&self, i: TypeResultField) -> Duration {
        self.results[Into::<usize>::into(i)]
    }

    pub fn set(&mut self, i: TypeResultField, v: Duration) {
        self.results[Into::<usize>::into(i)] = v;
    }

    pub fn extract(&mut self) -> ResultFields {
        let res = self.clone();
        *self = ResultFields::new();
        res
    }

    pub fn to_bytes(&self, bytes: &mut [u8]) {
        self.results
            .iter()
            .enumerate()
            .for_each(|(i, r)| LittleEndian::write_u128(&mut bytes[i * 16..], *r))
    }

    pub fn from_bytes(bytes: &[u8]) -> Self {
        ResultFields {
            results: (0..NB_FIELD)
                .map(|i| LittleEndian::read_u128(&bytes[i * 16..]))
                .collect(),
        }
    }

    fn get_from_str(&self, field: &str) -> Duration {
        self.results[POSSIBLE_RESULT_FIELD
            .iter()
            .position(|f| *f == field)
            .unwrap()]
    }
}

struct Fields {
    secret: i128,
    n: u16,
    t: u16,
    nb_byz: u16,
    byz_comp: ByzComp,
}

impl Default for Fields {
    fn default() -> Self {
        Fields {
            secret: 1808,
            n: 61,
            t: 20,
            nb_byz: 0,
            byz_comp: ByzComp::Sleeper,
        }
    }
}

#[derive(PartialEq)]
enum VariationData {
    Secret(Vec<i128>),
    N(Vec<u16>),
    T(Vec<u16>),
    NbByz(Vec<u16>),
    ByzComp(Vec<ByzComp>),
    None,
}

fn serde_n_to_i128(n: &JsonValue) -> i128 {
    if let JsonValue::Number(n) = n {
        n.as_i64().unwrap() as i128
    } else {
        panic!("Given array is not fully a number array")
    }
}

fn serde_n_to_u16(n: &JsonValue) -> u16 {
    if let JsonValue::Number(n) = n {
        n.as_u64().unwrap() as u16
    } else {
        panic!("Given array is not fully a number array")
    }
}

fn serde_n_to_byzcomp(n: &JsonValue) -> ByzComp {
    if let JsonValue::Number(n) = n {
        (n.as_u64().unwrap() as u8).into()
    } else {
        panic!("Given array is not fully a number array")
    }
}

impl VariationData {
    // Returns itself, the value of the element as an i128 and the length of the array
    fn from_serde_str(key: &str, vec: &[JsonValue]) -> (VariationData, i128, usize) {
        let len = vec.len();
        let first = serde_n_to_i128(&vec[0]);
        match key {
            "n" => (
                VariationData::N(vec.iter().map(serde_n_to_u16).collect()),
                first,
                len,
            ),
            "t" => (
                VariationData::T(vec.iter().map(serde_n_to_u16).collect()),
                first,
                len,
            ),
            "nb_byz" => (
                VariationData::NbByz(vec.iter().map(serde_n_to_u16).collect()),
                first,
                len,
            ),
            "secret" => (
                VariationData::Secret(vec.iter().map(serde_n_to_i128).collect()),
                first,
                len,
            ),
            "byz_comp" => (
                VariationData::ByzComp(vec.iter().map(serde_n_to_byzcomp).collect()),
                first,
                len,
            ),
            _ => panic!("The field {key} doesn't exists"),
        }
    }
}

struct Variation {
    data: VariationData,
    variation_index: usize,
    end: usize,
    variation_count: usize,
    n_per_variation: usize,
    conclusion: ResultFields,
}

impl Variation {
    fn new(data: VariationData, end: usize, n_per_variation: usize) -> Variation {
        Variation {
            data,
            end,
            n_per_variation,
            variation_index: 0,
            variation_count: 0,
            conclusion: ResultFields::new(),
        }
    }

    fn hmt(&self) -> usize {
        self.n_per_variation
    }

    fn evolve(&mut self, args: &mut Fields, result: ResultFields) -> (bool, Option<ResultFields>) {
        self.variation_count += 1;
        self.conclusion += result;
        if self.variation_count == self.n_per_variation {
            self.variation_count = 0;
            self.variation_index += 1;
            let conclusion = self.conclusion.extract();
            self.actualise_data(args);
            return (self.variation_index == self.end, Some(conclusion));
        }
        (false, None)
    }

    fn actualise_data(&self, args: &mut Fields) {
        let index = self.variation_index;
        if index < self.end {
            match &self.data {
                VariationData::N(n) => args.n = n[index],
                VariationData::T(t) => args.t = t[index],
                VariationData::Secret(secret) => args.secret = secret[index],
                VariationData::NbByz(nb_byz) => args.nb_byz = nb_byz[index],
                VariationData::ByzComp(byz_comp) => args.byz_comp = byz_comp[index],
                VariationData::None => (),
            }
        }
    }

    fn get_field_and_var(&self) -> (Vec<u32>, String) {
        match &self.data {
            VariationData::N(vec) => (vec.iter().map(|x| *x as u32).collect(), "n".to_string()),
            VariationData::T(vec) => (vec.iter().map(|x| *x as u32).collect(), "t".to_string()),
            VariationData::Secret(vec) => (
                vec.iter().map(|x| *x as u32).collect(),
                "secret".to_string(),
            ),
            VariationData::NbByz(vec) => (
                vec.iter().map(|x| *x as u32).collect(),
                "nb_byz".to_string(),
            ),
            VariationData::ByzComp(vec) => (
                vec.iter().map(|x| Into::<u8>::into(*x) as u32).collect(),
                "byz comp".to_string(),
            ),
            VariationData::None => (Vec::new(), String::new()),
        }
    }
}

#[derive(Clone, Copy, PartialEq)]
pub enum ByzComp {
    Honnest,
    Sleeper,
}

impl From<u8> for ByzComp {
    fn from(code: u8) -> Self {
        match code {
            0 => ByzComp::Sleeper,
            1 => ByzComp::Honnest,
            _ => panic!("Invalid code: {code}"),
        }
    }
}

impl From<ByzComp> for u8 {
    fn from(val: ByzComp) -> Self {
        match val {
            ByzComp::Sleeper => 0,
            ByzComp::Honnest => 1,
        }
    }
}

struct SubArgs {
    fields: Fields,
    variation: Variation,
    result: HashMap<ResultField, Vec<Duration>>,
}

impl SubArgs {
    
    fn new_with_field(
        fields: Fields,
        variation: Variation,
        asked_fields: &[ResultField],
    ) -> SubArgs {
        let mut result = HashMap::<ResultField, Vec<Duration>>::new();
        for field in asked_fields.iter() {
            result.insert(field.to_string(), Vec::new());
        }
        SubArgs {
            fields,
            variation,
            result,
        }
    }

    fn evolve(&mut self, result: ResultFields) -> bool {
        let (stop, conclusion) = self
            .variation
            .evolve(&mut self.fields, result);
        if let Some(conclusion) = conclusion {
            self.result.iter_mut().for_each(|(k, vec)| {
                vec.push(
                    conclusion.get_from_str(k) / self.variation.hmt() as u128,
                )
            });
        }
        stop
    }

    fn correct_threshold(&mut self) {
        if self.fields.t != 0 && self.fields.n > 0 {
            self.fields.t = (self.fields.n - 1) / 3
        }
    }

    fn get_field_and_var(&self) -> (Vec<u32>, String, Vec<(String, u32)>) {
        let (vec, field) = self.variation.get_field_and_var();
        let mut base_state = [
            ("n", self.fields.n as u32),
            ("t", self.fields.t as u32),
            ("nb_byz", self.fields.nb_byz as u32),
            ("byz_comp", Into::<u8>::into(self.fields.byz_comp) as u32),
            ("secret", self.fields.secret as u32),
        ]
        .iter()
        .map(|(f, v)| (f.to_string(), *v))
        .collect::<Vec<_>>();
        base_state.remove(base_state.iter().position(|(f, _)| *f == field).unwrap());
        (vec, field, base_state)
    }

    fn compute_debit(&self, debit: u64) -> Vec<u64> {
        self.result
            .get("total")
            .unwrap()
            .iter()
            .map(|v| (1_000 * debit as u128 / *v) as u64)
            .collect()
    }
}

#[derive(Default)]
pub struct Args {
    args: Vec<SubArgs>,
    current_arg: usize,
    output: String,
    reconstruct: bool,
    debit: u64,
}

impl Args {
    fn get_fields(&self) -> &Fields {
        &self.args[self.current_arg].fields
    }

    pub fn evolve(&mut self, result: ResultFields) -> bool {
        if self.args[self.current_arg].evolve(result) {
            self.current_arg += 1;
        }
        if self.current_arg >= self.args.len() {
            self.conclude();
            true
        } else {
            false
        }
    }

    pub fn conclude(&mut self) {
        if !self.output.is_empty() {
            let vec = JsonValue::Array(
                self.args
                    .iter()
                    .map(|arg| {
                        let result_map = serde_json::to_value(&arg.result)
                            .expect("Failed to convert in json value");
                        let mut map = serde_json::Map::new();
                        let (variation, field, base_state) = arg.get_field_and_var();
                        map.insert("field".to_string(), field.into());
                        map.insert("variation".to_string(), variation.into());
                        for (f, v) in base_state {
                            map.insert(f, v.into());
                        }
                        if self.debit != NO_DEBIT {
                            map.insert("debit".to_string(), arg.compute_debit(self.debit).into());
                        }
                        JsonValue::Array(vec![JsonValue::Object(map), result_map])
                    })
                    .collect::<Vec<JsonValue>>(),
            );
            if !self.output.ends_with(".json") {
                self.output += ".json";
            }
            let file = File::create(format!("../configs/results/{}", self.output))
                .expect("Failed to create file");
            let mut writer = BufWriter::new(file);
            writer
                .write_all(serde_json::to_string_pretty(&vec).unwrap().as_bytes())
                .expect("Failed to write");
            writer.flush().expect("Failed to flush");
        }
    }

    pub fn n(&self) -> u16 {
        self.get_fields().n
    }

    pub fn t(&self) -> u16 {
        self.get_fields().t
    }

    pub fn secret(&self) -> i128 {
        self.get_fields().secret
    }

    pub fn nb_byz(&self) -> u16 {
        self.get_fields().nb_byz
    }

    pub fn byz_comp(&self) -> ByzComp {
        self.get_fields().byz_comp
    }

    fn handle_args(res: &mut Args, args: &JsonValue) -> (usize, Vec<ResultField>) {
        let mut hmt = 1;
        let mut asked_field = Vec::<ResultField>::new();
        let args = if let JsonValue::Object(obj) = args {
            obj
        } else {
            panic!("Invalid json file")
        };
        for (key, value) in args.iter() {
            let key = key as &str;
            match key {
                "hmt" => {
                    hmt = if let JsonValue::Number(n) = value {
                        n.as_u64().unwrap() as usize
                    } else {
                        panic!("Hmt should be a number")
                    }
                },
                "output" => {
                    if let JsonValue::String(s) = value {
                        res.output = s.to_string()
                    } else {
                        panic!("output should be a str")
                    }
                },
                "debit" => {
                    if let JsonValue::Number(n) = value {
                        res.debit = n.as_u64().unwrap();
                        let total = String::from("total");
                        if !asked_field.contains(&total) {
                            asked_field.push(total)
                        }
                    } else {
                        panic!("debit should be a number")
                    }
                },
                "reconstruct" => {
                    if let JsonValue::Bool(b) = value {
                        res.reconstruct = *b;
                        let key = key.to_string();
                        if *b && !asked_field.contains(&key) {
                            asked_field.push(key)
                        }
                    } else {
                        panic!("reconstuct should be a boolean")
                    }
                },
                _ if POSSIBLE_RESULT_FIELD.contains(&key) => {
                    if let JsonValue::Bool(b) = value {
                        let key = key.to_string();
                        if *b && !asked_field.contains(&key) {
                            asked_field.push(key)
                        }
                    } else {
                        panic!("Boolean missing")
                    }
                },
                _ => panic!("This field doesn't exist: {key}"),
            }
        }
        (hmt, asked_field)
    }

    pub fn from_file(path: String) -> Args {
        let mut res = Args {
            args: Vec::<SubArgs>::new(),
            output: String::new(),
            current_arg: 0,
            reconstruct: false,
            debit: NO_DEBIT,
        };
        let content = read_to_string(path).expect("Path invalid");
        let value: JsonValue = from_str(&content).expect("The given json file is invalid");
        let json_args = if let JsonValue::Array(vec) = value {
            vec
        } else {
            panic!("The json root is not an array")
        };
        let (hmt, asked_result) = Self::handle_args(&mut res, &json_args[0]);
        for sim in json_args.iter().skip(1) {
            let sim = if let JsonValue::Object(obj) = sim {
                obj
            } else {
                panic!("the json file root array is not only composed by objects")
            };
            let mut variation = VariationData::None;
            let mut fields = Fields::default();
            let mut len = 1;
            for (key, value) in sim.iter() {
                let init_val = match value {
                    JsonValue::Array(arr) => {
                        if variation == VariationData::None {
                            let first: i128;
                            (variation, first, len) = VariationData::from_serde_str(key, arr);
                            first
                        } else {
                            panic!("Two variations declared")
                        }
                    },
                    JsonValue::Number(n) => n.as_i64().unwrap() as i128,
                    _ => panic!("Unexcpected Value in object"),
                };
                match key as &str {
                    "n" => fields.n = init_val as u16,
                    "t" => fields.t = init_val as u16,
                    "nb_byz" => fields.nb_byz = init_val as u16,
                    "secret" => fields.secret = init_val,
                    "byz_comp" => fields.byz_comp = (init_val as u8).into(),
                    _ => panic!("The field {key} doesn't exist"),
                }
            }
            let variation = Variation::new(variation, len, hmt);
            res.args.push(SubArgs::new_with_field(
                fields,
                variation,
                &asked_result,
            ))
        }
        res
    }

    pub fn correct_threshold(&mut self) {
        self.args[self.current_arg].correct_threshold();
    }

    pub fn reconstruct(&self) -> bool {
        self.reconstruct
    }
}
