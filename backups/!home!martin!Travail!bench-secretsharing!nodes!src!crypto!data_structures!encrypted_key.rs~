use serde::{Serialize, Deserialize};

#[derive(Serialize, Deserialize)]
pub struct EncryptedKey {
    key: G1Projective,
    index: u16
}

impl EncryptedKey {

    pub fn new(key: G1Projective, index: u16) -> Self {
        EncryptedKey {
            key,
            index
        }
    }
    
    pub fn key(&self) -> &G1Projective {
        self.key
    }

    pub fn index(&self) -> u16 {
        self.index
    }
    
}
