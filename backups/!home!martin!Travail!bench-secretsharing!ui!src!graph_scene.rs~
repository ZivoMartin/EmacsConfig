
fn build_scene_graphs(stack: &Stack, path: String) -> Fixed {
    let fixed = Fixed::new();
    let back_button = button(&fixed, "Back", 0, 0, 50, 20);
    let cloned_stack = stack.clone();
    back_button.connect_clicked(move |_| {
        cloned_stack.set_visible_child_name("scene_settings");
    });
    (0..generate_pngs(path)).for_each(|i| {
        match gtk::gdk_pixbuf::Pixbuf::from_file(&format!("{i}.png")) {
            Ok(pixbuf) => {
                let image = Image::builder().pixbuf(&pixbuf).build();
                fixed.put(&image, 60 + 700*(i%2) as i32*if i==3 {2} else {1}, 60 + if i == 3 { 700 } else { 0 });
            }
            Err(err) => eprintln!("Erreur lors du chargement de l'image: {}", err)
        }       
    });
    fixed
}

fn generate_pngs(path: String) -> usize {    
    let content = read_to_string(path).expect("Path invalid");
    let value: JsonValue = from_str(&content).expect("The given json file is invalid");    
    let global_vec = if let JsonValue::Array(ref global_vec) = value {        
        global_vec
    } else {
        unreachable!()
    };
    for (i, vec) in global_vec.iter().enumerate() {
        let vec = if let JsonValue::Array(ref json_vec) = vec {
            json_vec
        } else {
            unreachable!()
        };
        let args = if let JsonValue::Object(ref json_args) = vec[0] {
            json_args
        } else {
            unreachable!()
        };
        let varied = if let JsonValue::String(ref json_varied) = args["field"] {
            json_varied
        } else {
            unreachable!()
        };
        let variation = if let JsonValue::Array(ref json_var) = args["variation"] {
            json_var
        } else {
            unreachable!()
        }.iter().map(|n| if let JsonValue::Number(json_n) = n { json_n.as_u64().unwrap() as u16 } else { unreachable!() }).collect::<Vec<u16>>();
        let json_results = if let JsonValue::Object(ref json_results) = vec[1] {
            json_results
        } else {
            unreachable!()
        };

        let mut result_fields = Vec::<&str>::new();
        let mut results = Vec::<Vec<u16>>::new();
        json_results.iter().for_each(|(field, value)| {
            result_fields.push(field as &str);
            results.push(if let JsonValue::Array(ref json_result) = value {
                json_result
            } else {
                unreachable!()
            }.iter().map(|n| if let JsonValue::Number(json_n) = n { json_n.as_u64().unwrap() as u16 } else { unreachable!() }).collect());
        });
        plot_with_gnuplot(varied, &variation, &results, &result_fields, &format!("{i}.png"));
    }
    global_vec.len()
}

