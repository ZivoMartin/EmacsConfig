#include "Source.hpp"
#include "Env.hpp"

Source::Source(Env* env) {
	this->env = env;
}

Source::~Source() {}

Env* Source::get_env() const {
	return env;
}

SDL_Renderer* Source::get_ren() const {
	return get_env()->get_ren();
}

SDL_Window* Source::get_win() const {
	return get_env()->get_win();
}


int Source::get_width() {
	return this->width;
}

int Source::get_height() {
	return this->height;
}

void Source::set_width(int w) {
	this->width = w;
}

void Source::set_height(int h) {
	this->height = h;
}

void Source::set_size(int w, int h) {
	set_width(w);
	set_height(h);
}
