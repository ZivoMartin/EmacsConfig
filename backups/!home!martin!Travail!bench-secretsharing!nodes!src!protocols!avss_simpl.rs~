use crate::*;

struct Polynomial;

type Commitment = i32;
type Witness = i32;
type Share = i128;
type Proof = i128;

impl Polynomial {
    
    fn new(_secret: i128) -> Polynomial {
        Polynomial
    }

    fn get(&self, _i: usize) -> Share {
        1
    }
    
    fn open(&self, _i: usize, _w: Witness) -> Proof {
        2
    }

    fn commit(&self, _n: usize) -> (Commitment, Witness) {
        (3, 4)
    }
}

fn deg_check(_commitment: Commitment, _deg: usize) -> bool {
    true
}

fn verify(_v: Commitment, _index: usize, _share: Share, _proof: Proof) -> bool {
    true
}

pub async fn deal(network: Vec<String>, mut receiver: Receiver<DealerMessage>, secret: String, _is_corrupted: bool) {
    let secret = secret.parse::<i128>().expect("Failed to convert secret in number");
    let n = network.len();
    let pol = Polynomial::new(secret);
    let (v, w) = pol.commit(n);
    let mut shares = HashMap::<usize, (usize, Proof, Share)>::new();
    for i in (0..n).rev() {       
        let proof = pol.open(i, w);
        let share = pol.get(i);
        shares.insert(i, (i, proof, share));
        private_message(&network[i], &format!("SHARE/{v}/{}/{proof}", share)).await;
    }
    let mut signatures = Vec::<(usize, Sign)>::new();
    let deux_t_plus_un = n - (n-1)/3;
    loop {
        match receiver.recv().await {
            Some(m) => match m {
                DealerMessage::Message(i, sign) => {
                    shares.remove(&i);
                    signatures.push((i, sign));
                    if signatures.len() == deux_t_plus_un {
                        break
                    }
                }
            }
            None => break
        }
    }
    println!("{}", signatures.len());
    let mut missing_shares = Vec::<(usize, Proof, Share)>::new();
    for (_, val) in shares {
        missing_shares.push(val)
    }
    println!("{missing_shares:?}");
}


pub async fn first_receiv(node: Wrapped<Node>, v: String, share: String, proof: String) {
    let n = node.lock().await.network.len();
    let v = v.parse::<Commitment>().expect("Failed to convert commitment in number");
    let share = share.parse::<Share>().expect("Failed to convert share in number");
    let proof = proof.parse::<Proof>().expect("Failed to convert proof in number");
    let node = node.lock().await;
    if deg_check(v, (n-1)/3) && verify(v, node.index, share, proof) {
        let sign = node.sign();
        private_message(&node.network[0], &format!("ACK/{i}/{sign}", i=node.index)).await;
    }
}

