#include "../include/settings.h"

#define CHECKBOX_UNFILLED 255, 255, 255, 255
#define CHECKBOX_FILLED 0, 0, 0, 255

Checkbox* create_checkbox(Button* b) {
	Checkbox* res = malloc(sizeof(Checkbox));
	b->checkbox = res;
	res->filled = false;
	b->action = fill_checkbox;
	button_change_color(b, lablib_create_color(CHECKBOX_UNFILLED));
}

bool checkbox_filled(Checkbox* cb) {
	return cb->filled;
}

void fill_checkbox(Button* b) {
	if (checkbox_filled(button_get_checkbox(b)))
		button_change_color(b, lablib_create_color(CHECKBOX_FILLED));
	else
		button_change_color(b, lablib_create_color(CHECKBOX_UNFILLED));
	button_get_checkbox(b)->filled = !button_get_checkbox(b)->filled;
}

