#include "MapEntity.hpp"


MapEntity::MapEntity(Env* env, const char* path, SDL_Point pos, float fx, float fy) : Sprite(env, path, fx, fy), Movable(env) {
	this->pos = {PIXEL_TILE_SIZE*pos.x, PIXEL_TILE_SIZE*pos.y};
}

MapEntity::~MapEntity() {}


SDL_Point* MapEntity::get_pos() {
	return &this->pos;
}

void MapEntity::update() {
	Movable::update();
	Sprite::update();
}

void MapEntity::set_interactible() {
	can_interact_with_player = true;
}

bool MapEntity::get_can_interact_with_player() {
	return can_interact_with_player;
}

void draw(int x, int y) {
	Movable::draw(x, y);
}
