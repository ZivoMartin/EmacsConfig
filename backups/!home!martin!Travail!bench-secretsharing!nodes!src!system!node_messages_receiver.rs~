use crate::*;

pub async fn new_command<'a>(node: Wrapped<Node>, bytes_message: &[u8]) {
    match bytes_message[0].into() {
        NodeCommand::DEALTHIS => setup_deal(node, &bytes_message[1..]).await,
        NodeCommand::SETUP => setup(node, &bytes_message[1..]).await,
        NodeCommand::KEY => new_key(node, &bytes_message[1..]).await,
        NodeCommand::RECONSTRUCT => reconstruct(node).await,
        NodeCommand::STOP => stop_reconstruct(node).await,
        NodeCommand::KILL => kill_myself(node).await
    };
}

async fn setup(node: Wrapped<Node>, bytes: Bytes<'_>) {
    let mut node = node.lock().await;
    log("Prepare to setup");
    node.im_done = false;
    node.im_setup = false;
    node.step = Step::Sharing;
    node.op_id = LittleEndian::read_u32(bytes);
    node.dealer = LittleEndian::read_u16(&bytes[4..]);
    node.byz_comp = bytes[2].into();
    node.t = LittleEndian::read_u16(&bytes[7..]);
    node.l = LittleEndian::read_u16(&bytes[9..]);
    let n = LittleEndian::read_u16(&bytes[11..]);
    node.n = n;
    if node.n > node.network.len() as u16 {
        node.connected_node = node.network.len() as u16;
        let (network, _) = read_ip_vec(&bytes[11..]);
        for addr in network.iter().skip(node.network.len()) {
            node.network.push(ExternNode::new(vec![], addr.to_string()));
        }
        if node.connected_node == 0 {
            node.set_index();
        }
        let key = node.encode_key();
        for node in node.network.iter().skip(node.connected_node as usize) {
            private_message(node.addr(), &key).await;
        }
    }
    node.shares.clear();
    node.im_setup = true;
    node.log("Setup is over.")
}

async fn new_key(node: Wrapped<Node>, bytes: Bytes<'_>) {
    node.lock()
        .await
        .log("I got a new key, just waiting to be setup");
    loop {
        if node.lock().await.im_setup {
            break;
        }
    }
    node.lock().await.log("Im setup, lets save the key");
    let i = LittleEndian::read_u16(bytes);
    let key = bytes[2..].to_vec();
    node.lock().await.network[i as usize].p_key = key;
    node.lock().await.connected_node += 1
}

async fn im_ready(node: Wrapped<Node>) {
    node.lock().await.log("Waiting to be ready");
    loop {
        let node = node.lock().await;
        if node.im_setup && node.network.len() <= node.connected_node as usize {
            break;
        }
    }
    node.lock().await.log("Im ready !");
}

async fn setup_deal(node: Wrapped<Node>, bytes: Bytes<'_>) {
    node.lock().await.log("Im the dealer, waiting to be ready.");
    im_ready(node.clone()).await;
    node.lock().await.log("Dealer is ready");
    match bytes[0].into() {
        Algo::AvssSimpl => avss_simpl::messages_receiver::setup_deal(node, &bytes[1..]).await
    }
}



async fn reconstruct(node: Wrapped<Node>) {
    node.lock().await.log("Lets reconstruct");
    while node.lock().await.is_actif {}
    let (network, message): (_, Vec<u8>) = {
        let mut node = node.lock().await;
        node.step = Step::Reconstruct;
        node.reconstruct_share_set = node.shares.clone();
        node.is_actif = true;
        node.im_done = false;
        node.stop = false;
        node.timer = Instant::now();
        if node.byz_comp == ByzComp::Sleeper {
            return;
        }
        let mut message = vec![0; 4];
        message[0] = NameSpace::AvssSimpl.into();
        message[1] = AvssSimplCommand::NEWSHARE.into();
        LittleEndian::write_u16(&mut message[2..], node.index);
        node.my_share().append(&mut message);
        node.my_proof().append(&mut message);
        node.log("Message just finished to be computed");
        (node.get_current_network(), message)
    };
    let message = Arc::from(Mutex::from(message.to_vec()));
    for ext_node in network {
        if node.lock().await.stop {
            node.lock().await.log("Interruption of the broadcast");
            break;
        }
        let addr = ext_node.addr.clone();
        let message = message.clone();
        tokio::spawn(async move {
            private_message(&addr, &message.lock().await).await;
        });
    }
    node.lock().await.is_actif = false;
    node.lock().await.log("Broadcast is over");
}

pub async fn stop_reconstruct(node: Wrapped<Node>) {
    node.lock().await.log("Interrupting broadcast...");
    node.lock().await.stop = true;
    node.lock()
        .await
        .output(Step::Reconstruct, ErrorCode::OK)
        .await;
}

async fn kill_myself(node: Wrapped<Node>) {
    node.lock().await.log("I kill myself");
