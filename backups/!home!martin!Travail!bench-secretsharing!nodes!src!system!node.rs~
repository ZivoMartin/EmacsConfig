use super::*;

pub struct Node {
    pub t: u16,
    pub n: u16,
    pub l: u16,
    pub interface_ip: String,
    pub connected_node: u16,
    pub port: u16,
    pub network: Vec<ExternNode>,
    pub dealer: u16,
    pub byz_comp: ByzComp,
    pub index: u16,
    pub dealer_sender: Option<Sender<DealerMessage>>,
    pub keys: KeyPair,
    pub im_setup: bool,
    pub shares: ShareSet,
    pub reconstruct_share_set: ShareSet,
    pub timer: Instant,
    pub result: ResultFields,
    pub im_done: bool,
    pub stop: bool,
    pub step: Step,
    pub is_actif: bool,
    pub log_file: File,
    pub op_id: u32,
}

impl Node {
    
    pub async fn new(interface_ip: String, port: u16) -> Node {
        Node {
            t: 0,
            n: 0,
            l: 0,
            interface_ip,
            timer: Instant::now(),
            connected_node: 0,
            network: Vec::new(),
            dealer: 0,
            index: 0,
            byz_comp: ByzComp::Honnest,
            dealer_sender: None,
            keys: KeyPair::generate(&rcgen::PKCS_ED25519).expect("Failed to construct key"),
            im_setup: false,
            im_done: false,
            shares: ShareSet::new(),
            reconstruct_share_set: ShareSet::new(),
            stop: false,
            port,
            result: ResultFields::new(),
            step: Step::Sharing,
            is_actif: false,
            log_file: create_or_open("commun_log_file"),
            op_id: 0,
        }
    }

  
    pub fn set_index(&mut self) {
        let index = self
            .network
            .iter()
            .position(|addr| extract_port(addr.addr()) == self.port)
            .unwrap() as u16;
        self.log_file = create_or_open(&format!("node_logs_{index}"));
        self.index = index
    }

    pub fn encode_key(&mut self) -> Vec<u8> {
        let mut buf = vec![0; 4];
        self.log("I encode my key...");
        buf[0] = NameSpace::Node.into();
        buf[1] = NodeCommand::KEY.into();
        LittleEndian::write_u16(&mut buf[2..], self.index);
        let mut p_key = self.keys.public_key_der();
        buf.append(&mut p_key);
        buf
    }

    pub fn get_current_network(&self) -> Vec<ExternNode> {
        self.network[0..self.n as usize].to_vec()
    }

    pub fn save_share(&mut self, i: u16, share: Share, proof: Proof) {
        self.log(&format!("Just got the share of the {i}th node"));
        self.get_current_set_mut().new_share(i, share, proof);
    }

    pub fn sign(&self) -> Sign {
        let pkcs8_bytes = self.keys.serialize_der();
        let ed_key_pair = Ed25519KeyPair::from_pkcs8(pkcs8_bytes.as_slice())
            .expect("Failed to parse private key");
        let signature = ed_key_pair.sign(SIGNATURE);
        signature.as_ref().to_vec()
    }

    pub fn my_share(&self) -> &Share {
        &self.get_current_set().get(self.index).0
    }

    pub fn my_proof(&self) -> &Proof {
        &self.get_current_set().get(self.index).1
    }

    pub fn get_current_set(&self) -> &ShareSet {
        match self.step {
            Step::Sharing => &self.shares,
            Step::Reconstruct => &self.reconstruct_share_set,
        }
    }

    pub fn get_current_set_mut(&mut self) -> &mut ShareSet {
        match self.step {
            Step::Sharing => &mut self.shares,
            Step::Reconstruct => &mut self.reconstruct_share_set,
        }
    }

    pub fn im_dealer(&self) -> bool {
        self.index == self.dealer
    }

    pub fn log(&mut self, the_log: &str) {
        if VERBOSE {
            self.log_file
                .write_all(format!("Node {}: {the_log}\n", self.index).as_bytes())
                .expect("Failed to write in file");
        }
    }

    
    pub async fn output(&mut self, step: Step, code: ErrorCode) {
        self.log("Prepare to output !");
        if self.im_done {
            self.log("But im already done..");
            return;
        }
        if self.im_dealer() && step == Step::Sharing {
            self.result
                .set(TypeResultField::Total, self.timer.elapsed().as_millis());
        } else if step == Step::Reconstruct {
            self.result.set(
                TypeResultField::Reconstruction,
                self.timer.elapsed().as_millis(),
            );
        }
        let mut msg = [0; RESULT_FIELDS_SIZE + 1];
        msg[0] = InterfaceCode::OUTPUT.into();
        self.im_done = true;
        self.result.extract().to_bytes(&mut msg[1..], code);
        log("Successfully output");
        self.is_actif = false;
        private_message(&self.interface_ip, &msg).await
    }

}
