#[macro_export]
macro_rules! dec {
    ($bytes:expr, $t:ty) => {
        {
            let res: ($t) = bincode::deserialize(&($bytes[..])).unwrap();
            let size = bincode::serialized_size(&res).unwrap() as usize;
            (res, size)
        }
    };
}

#[macro_export]
macro_rules! enc {
    ($var:expr, $bytes:expr) => {
        match bincode::serialize(&$var) {
            Ok(mut serialized) => $bytes.append(&mut serialized),
            Err(e) => eprintln!("Serialization error: {:?}", e)
        }
    };
}
