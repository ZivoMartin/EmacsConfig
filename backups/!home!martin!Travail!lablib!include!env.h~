#ifndef SAFE_ENV
#define SAFE_ENV
#include "struct.h"

/**
 * @brief Allocate the entire env and return it.
 * @param win The sdl window
 * @param ren The sdl renderer 
 * @param filename The path to the default game
 * @details Set the game as game_default if the path is empty
 * @return The env
 */
Env * init(SDL_Window* win, SDL_Renderer* ren,char* filename);


/**
 * @brief Destroy the entire env
 * @param env The env
 */
void destroy_env(Env* env);

/**
 * @brief init all the scenes of the game.
 * @param env The env.
 */
void init_scenes(Env* env);

/**
 * @brief Built the ten textures for the ten digits and store it in the env
 * @param env The env
 */
void init_numbers_texture(Env* env);

/**
 * @brief Init specifically the game scene
 * @param env The env
 */
void init_game_scene(Env* env); 

/**
 * @brief Init specifically the game setting scene
 * @param env The env
 */
void init_setting_scene(Env* env); 

/**
 * @brief Init specifically the menu scene
 * @param env The env
 */
void init_menu_scene(Env* env); 


/**
 * @brief Initialises the frames of the squares of our game
 * 
*/
void init_frames_Array(Env* env);


/**
 * @brief Handle a clic on the grid
 * @param env The env
 * @param c The coordinates of the clic relative to the top left corner of the grid
 */
void click_on_grid(Button* b);

void set_game(Env* env, game g);

/**
 * @brief Get the sdl window of the env
 * @param env The env
 * @return The sdl window
 */
SDL_Window* win(Env* env);

/**
 * @brief Get the current game of the env
 * @param env The env
 * @return The current game
 */
game get_game(Env* env);

/**
 * @brief returns the correct frame based on the current color of the square 
*/
SDL_Texture* get_frame_texture(Env* env, color c);


/**
 * @brief Get the height of the window
 * @param env The env
 * @return The height of the window
 */
int w_height(Env* env);

/**
 * @brief Get the width of the window
 * @param env The env
 * @return The width of the window
 */
int w_width(Env* env);

/**
 * @brief Indicate if the app is running
 * @param env The env
 * @return true if its running otherwise false
 */
bool running(Env* env);

/**
 * @brief Get the number of button of the current scene
 * @param env The env
 * @return The number of button of the current scene
 */
int nb_button(Env* env);


/**
 * @brief Get the ith button of the current scene
 * @param env The env
 * @param index The requested button index
 * @return The ith button of the current scene
 */
Button* get_button(Env* env, int index);

/**
 * @brief Get the index of the current scene
 * @param env The env
 * @return the index of the current scene
 */
SceneIndex get_scene_index(Env* env);

/**
 * @brief Get the ith scene
 * @param env The env
 * @param i The index of the scene by using the enum type SceneIndex
 * @details If you want the current scene use get_current scene, use this function only if you want a specific one
 * @return The ith scene
 */
Scene* get_scene(Env* env, SceneIndex i);

/**
 * @brief Get the current scene, not his index but the pointer on the current scene itself
 * @param env The env
 * @return The current scene
 */
Scene* get_current_scene(Env* env);

/**
 * @brief Get the sdl renderer of the env
 * @param env The env
 * @return The sdl renderer
 */
SDL_Renderer* get_ren(Env* env);

/**
 * @brief Get the text font stored in the env
 * @param env The env
 * @return The font
 */
TTF_Font* get_font(Env* env);

/**
 * @brief This function do a quite specific job, store a sdl texture with the text "$i" in a given emplacment, is only use in the init_numbers_texture function
 * @param env The env
 * @param t The memory spot to store the texture
 * @param i The number to put inside the texture as a text
 * @param r The red intensity
 * @param g The green intensity
 * @param b The blue intensity
 * @return The sdl renderer
 */
void save_number_texture(Env* env, SDL_Texture** t, int i, int r, int g, int b);

/**
 * @brief Computes the size of a tile in the game
 * @param env The env
 * @return the tile size
 */
int compute_ts(Env *env);

/**
 * @brief Change the index of the current scene
 * @param env The env
 * @param new_scene The new scene
 * @details Care, this function take the INDEX of the new scene, not the scene itself.
 */
void change_scene(Env* env, SceneIndex new_scene);

/**
 * @brief handle the press of a key on the application
 * @param env The env
 * @param c   The contents of the key just pressed as a char 
 */
void kpress(Env* env, char c);

/**
 * @brief Quit the app
 * @param env The env
 */
void quit_app(Button* b);

