Env* init(SDL_Window *win, SDL_Renderer *ren, char * filename) {
  Env *env = malloc(sizeof(struct Env_t));
  SDL_SetRenderDrawBlendMode(ren, SDL_BLENDMODE_BLEND);
  env->current_scene = Menu;
  env->running = true;
  if (filename == NULL || filename[0] == '\0') {
    env->g = game_default();
  } else {
    env->g = cp(game_load(filename));
  }
  env->is_searching = false;
  env->ren = ren;
  env->win = win;
  init_frames_Array(env);
  if (TTF_Init() != 0) ERROR("Error: TTF_Init (%s)", SDL_GetError());
  env->font = cp(TTF_OpenFont(FONT, FONTSIZE));
  TTF_SetFontStyle(env->font, TTF_STYLE_NORMAL);
  init_numbers_texture(env);
  init_scenes(env);
  return env;
}

#define FIRST_UNVALID_ZONE 0.2
#define SECOND_UNVALID_ZONE 0.8

bool is_on_valid_tile_part(SDL_Point c, int tileSize, int i, int j) {
  c.x -= j*tileSize;
  c.y -= i*tileSize;
  return c.x > tileSize*FIRST_UNVALID_ZONE && c.x < tileSize*SECOND_UNVALID_ZONE && c.y > tileSize*FIRST_UNVALID_ZONE && c.y < tileSize*SECOND_UNVALID_ZONE;
}

void stop_the_search(Env* env) {
  if (env->is_searching) {
    int s = pthread_cancel(env->solve_thread);
    if (s != 0) {
      printf("Error during the cancel of the thread\n");
    }
    //pthread_join(env->solve_thread, NULL);
  }
}

void click_on_grid(Button* b) {
  Env* env = button_env(b);
  SDL_Point c = get_last_coordinate(env);
  int tileSize = compute_ts(env);
  int decalWidth, decalHeight;
  compute_decal_grid(button_env(b), tileSize, &decalWidth,&decalHeight);
  c.x -= decalWidth;
  c.y -= decalHeight;
  int i = ((float)(c.y)/(float)(game_nb_rows(get_game(env))*tileSize))*game_nb_rows(get_game(env));
  int j = ((float)(c.x)/(float)(game_nb_cols(get_game(env))*tileSize))*game_nb_cols(get_game(env));
  if (is_on_valid_tile_part(c, tileSize, i, j)) {
    if (game_get_color(get_game(env), i, j) == WHITE) {
      game_play_move(get_game(env), i, j, BLACK);
    } else if (game_get_color(get_game(env), i, j) == BLACK) {
      game_play_move(get_game(env), i, j, EMPTY);
    }else {
      game_play_move(get_game(env), i, j, WHITE);
    }
  }
}


bool try_to_click_on_grid(Button* b, SDL_Point c) {
    input_set_activity(button_get_input(b), false);
    Env* env = button_env(b);
    int tileSize = compute_ts(env);
    int decalWidth, decalHeight;
    compute_decal_grid(env, tileSize, &decalWidth, &decalHeight);
    if (!env->is_searching && c.x > decalWidth && c.x < decalWidth+tileSize*game_nb_cols(get_game(env)) && 
         c.y > decalHeight && c.y < decalHeight + tileSize*game_nb_rows(get_game(env))) {
            (*b->action)(b);
            return true;
        }

    return false;
}


void new_clic(Env* env) {
  int n = nb_button(env);
  for(int i=0; i<n; i++) {
    if (get_scene_index(env) == Game && i == GRID_BUTTON_INDEX) {
      try_to_click_on_grid(get_button(env, GRID_BUTTON_INDEX), get_last_coordinate(env));
    }else{
      Scene* previous_scene = get_current_scene(env);
      try_to_click(get_button(env, i), get_last_coordinate(env));
      if (previous_scene != get_current_scene(env)) break;  // We stop only if there is a scene change, otherwise we continue to try to click.
    }
  }
}

void destroy_env(Env* env){
  for(SceneIndex i=0; i<Nb_Scene; i++) {
    destroy_scene(get_scene(env, i));
  }

  if (!env->is_searching) game_delete(get_game(env));   // The only case where we don't free this game is when the user quits the app during the solve. But it doesn't matter because its the end of the program.
  SDL_DestroyRenderer(get_ren(env));
  SDL_DestroyWindow(win(env));
  TTF_CloseFont(get_font(env));
}

