void* solve_thread(void* void_env) {
  Env* env = void_env;
  env->is_searching = true;
  game_solve(get_game((Env*) env));
  env->is_searching = false;
  return NULL;
}

void solve(Button* b) {
  Env* env = button_env(b);
  pthread_create(&env->solve_thread, NULL, solve_thread, (void*) env);
}

void save_or_load(Button* b, bool is_save) {
  char* txt = input_get_text(button_get_input(b));
  char buffer[100];
  char* path = GTF_PATH;
  Input* inp = button_get_input(b);
  Env* env = button_env(b);
  int i = 0;
  while (path[i]) {
    buffer[i] = path[i];
    i++;
  }
  int j = 0;
  while (txt[j] && txt[j] != '|' && txt[j] != ' ') {
    if (txt[j] == '/') {
      input_set_placeholder_error(inp, BAD_CHAR_ERROR);
      reset_txt(inp);
      return;
    }
    buffer[i] = txt[j];
    j++;
    i++;
  }
  buffer[i] = 0;
  if (is_save) 
    game_save(get_game(env), buffer);
  else {
    game new_game = game_load(buffer);
    if (new_game) {
      game_delete(get_game(env));
      set_game(env, game_load(buffer));
      change_scene(env, Game);
      input_change_placeholder(inp, DEFAULT_PLACEHOLDER);
    }else{
      input_set_placeholder_error(inp, GAME_NOT_EXISTS_ERROR);
    }
  }
  reset_txt(inp);
}

void save(Button* b) {
  save_or_load(b, true);
}

void load(Button* b) {
  save_or_load(b, false);
}

void start_game(Button* b) {
  new_game_button_pressed(b);
  go_game(b);
}


