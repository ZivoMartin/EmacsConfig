void row_col_cursor_is_moving(Button* b) {
  char new_txt[] = {'N', 'b', ' ', 'c', 'o', 'l', 's', ' ', ':', ' ', '\0', '\0', '\0'};
  Env* env = button_env(b);
  Button* sleep_b = get_button(env, NbColsIndication);
  if (b == get_button(button_env(b), RowCursor)) {
    new_txt[3] = 'r';
    new_txt[5] = 'w';
    sleep_b = get_button(env, NbRowsIndication);
  }
  int new_val = MAX_GAME_SIZE*cursor_value(button_get_cursor(b)); 
  new_txt[10] = '0' + new_val;
  if (new_val >= 10) {
    new_txt[10] = '0' + (new_val / 10);
    new_txt[11] = '0' + (new_val % 10);
  }
  SDL_Surface* surf = TTF_RenderText_Blended(get_font(env), new_txt, create_color(WHITE_TEXT_COLOR, DEFAULT_TEXT_OPPACITY));  
  button_change_texture(sleep_b, SDL_CreateTextureFromSurface(get_ren(env), surf));
  SDL_FreeSurface(surf);
}


void change_neighborhood(Button* b) {
  Env* env = button_env(b);
  game g = get_game(env);
  for(MenuButtonsIndex i = NeighFull; i<=NeighOrthoExclude; i++){ 
    Button* the_b = get_button(env, i);
    if (the_b == b){
      g->neigh = NeighFull-i;
      select_button(the_b);
    } else{
      unselect_button(the_b);
    }
  }
}


void change_wrapping(Button* b) {
  Env* env = button_env(b);
  game g = get_game(env);
  Button* wf = get_button(env, WrappingFalse);
  Button* wt = get_button(env, WrappingTrue);
  if (b == wf) {
    g->wrapping = false;
    select_button(wf);
    unselect_button(wt);
  }else{
    g->wrapping = true;
    select_button(wt);
    unselect_button(wf);
  }
}


SDL_Texture* get_frame_texture(Env* env, color c){
  return env->frame_textures[c];
}

void change_difficulty(Button* b) {
  game g = get_game(button_env(b));
  change_current_game(button_env(b), game_nb_rows(g), game_nb_cols(g));
}