use public_ip;
use global_lib::*;

struct Manager;

impl Manager {

    fn new() -> Manager {
        Manager
    }

    async fn new_command(manag: Wrapped<Manager>, bytes: Bytes<'_>, interface_ip: String) {
        match bytes[0].into() {
            ManagerCode::GEN => Self::generate(manag, &bytes[1..], interface_ip).await
        }
    }
    
    async fn generate(_manag: Wrapped<Manager>, bytes: Bytes<'_>, interface_ip: String) {
        for _ in 0..bytes[0] {
            let ip = interface_ip.clone();
            tokio::spawn(async move {
                Command::new("../target/release/nodes")
                    .arg(&ip)
                    .status()
                    .await
                    .expect("Failed to create a new node");
            });
        }
    }
    
}

#[tokio::main]
async fn main() {
    let ip = public_ip::addr().await.expect("Failed to get public ip");
    let listener = TcpListener::bind(format!("{ip:?}:{MANAGER_PORT}")).await.expect("Failed to bind");
    let manag = Arc::new(Mutex::new(Manager::new()));
    loop {
        let (mut socket, ip) = listener.accept().await.unwrap();
        let manag = manag.clone();
        tokio::spawn(async move {
            let mut buf = [0; 5];
            loop {
                match socket.read(&mut buf).await {
                    Ok(0) | Err(_) => return,
                    Ok(n) => n,
                };
                let ip = format!("{}:{INTERFACE_PORT}", extract_ip(&ip.to_string()));
                Manager::new_command(manag.clone(), &buf, ip).await;
            }
        });
    }    
}
