fn build_scene_settings(stack: &Stack) -> Fixed {
    let fixed = Fixed::new();

    let from_file = input(&fixed, "Load from file", 400, 100);
    let load_button = button(&fixed, "Load", 420, 150, 90, 30);

    label(&fixed, "configs:", 460, 270, 110, 50);
    label(&fixed, "results:", 600, 270, 110, 50);

    if let Ok(entries) = read_dir("../configs/results") {
        for (i, entry) in entries.enumerate() {
            if let Ok(entry) = entry {
                if let Ok(file_name) = entry.file_name().into_string() {
                    if file_name.ends_with(".json") {
                        let file_button = button(&fixed, &file_name, 600, 320 + 60 * i as i32, 90, 30);
                        let cloned_stack = stack.clone();
                        let scene_name = format!("scene_graphs_{file_name}");
                        let scene = build_scene_graphs(stack, format!("../configs/results/{file_name}"));
                        stack.add_titled(&scene, &scene_name, "graphs");
                        file_button.connect_clicked(move |_| {
                           cloned_stack.set_visible_child_name(&scene_name);
                        });
                    }
                }
            }
        }
    }

    if let Ok(entries) = read_dir("../configs") {
        for (i, entry) in entries.enumerate() {
            if let Ok(entry) = entry {
                if let Ok(file_name) = entry.file_name().into_string() {
                    if file_name.ends_with(".json") {
                        let file_button = button(&fixed, &file_name, 460, 320 + 60 * i as i32, 90, 30);
                        file_button.connect_clicked(move |_| {
                            let mut msg = [0; 300];
                            msg[0] = InterfaceCode::FROMFILE.into();
                            for (i, b) in format!("../configs/{file_name}").bytes().enumerate() {
                                msg[i+1] = b
                            }
                            tokio::spawn(async move {
                                message_to_interface(&msg).await;
                            });               
                        });
                    }
                }
            }
        }
    }
    
    load_button.connect_clicked(move |_| {
        handle_load_button(&from_file);
    });

    fixed
}



fn handle_load_button(from_file: &gtk::EntryBuffer) {
    let mut msg = [0; 200];
    msg[0] = InterfaceCode::FROMFILE.into();
    let mut i = 1;
    for b in from_file.text().bytes() {
        msg[i] = b;
        i += 1;
    }
    tokio::spawn(async move {
        message_to_interface(&msg).await;
    });
}
